# .env.example - Copy to .env and fill in values
# NEVER commit .env to version control!

# Environment (development/production)
ENVIRONMENT=development
DEBUG=False

# Database - SQLite (current) or PostgreSQL (future)
# SQLite:
DATABASE_URL=sqlite:///./database/cheontec.db
# PostgreSQL (future):
# DATABASE_URL=postgresql://username:password@localhost:5432/sacco_db

# Security - MUST be set in production, no defaults!
SECRET_KEY=your-strong-secret-key-here-at-least-32-characters
SESSION_SECRET_KEY=another-strong-secret-key-for-sessions

# CORS - Comma-separated list of allowed origins
BACKEND_CORS_ORIGINS=https://yourdomain.com,https://api.yourdomain.com,http://localhost:3000,http://localhost:8000

# Database pool settings (for PostgreSQL)
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# Email (if needed)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@saccosystem.com

# Admin
ADMIN_EMAIL=admin@cheontec.com

# Account settings
ALLOW_SELF_REGISTRATION=True
SELF_REGISTRATION_REQUIRES_APPROVAL=True
DEFAULT_MEMBER_STATUS=pending